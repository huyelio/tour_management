@startuml TourManagement_ClassDiagram

' ============================
' THEME & LAYOUT
' ============================
skinparam backgroundColor #F8FAFC
skinparam defaultFontName Arial
skinparam defaultFontSize 11

skinparam class {
    BackgroundColor #DBEAFE
    BorderColor     #1D4ED8
    HeaderBackgroundColor #1D4ED8
    HeaderFontColor #FFFFFF
    HeaderFontStyle bold
    FontColor       #1E293B
    BorderThickness 1.5
    RoundCorner     8
}

skinparam interface {
    BackgroundColor #EDE9FE
    BorderColor     #7C3AED
    HeaderBackgroundColor #7C3AED
    HeaderFontColor #FFFFFF
    HeaderFontStyle bold
}

skinparam enum {
    BackgroundColor #FEF3C7
    BorderColor     #D97706
    HeaderBackgroundColor #D97706
    HeaderFontColor #FFFFFF
    HeaderFontStyle bold
}

skinparam note {
    BackgroundColor #F0FDF4
    BorderColor     #16A34A
}

skinparam package {
    BackgroundColor #F1F5F9
    BorderColor     #64748B
    FontStyle       bold
    FontColor       #1E293B
}

skinparam arrow {
    Color           #374151
    Thickness       1.5
}

' ============================
' CLIENT – ReactJS
' ============================
package "Client – ReactJS" #E0F2FE {

    package "pages" {
        class TourListPage {
            +render() : JSX
        }
        class TourDetailPage {
            -id : String
            -tour : Object
            -showAssignForm : boolean
            -showTourForm   : boolean
            -success : String
            +fetchTour() : void
            +handleCancelTour() : void
            +render() : JSX
        }
    }

    package "components/tour" {
        class TourCard {
            -tour    : TourSummaryDTO
            -onEdit  : Function
            -onCancel: Function
            +render() : JSX
        }
        class TourList {
            -tours           : TourSummaryDTO[]
            -loading         : boolean
            -search          : String
            -statusFilter    : String
            -assignmentFilter: String
            -showForm        : boolean
            -editingTour     : Object
            +fetchTours()    : void
            +handleEdit(tour): void
            +handleCancel(id, name): void
            +handleFormSuccess(): void
            +render() : JSX
        }
        class TourForm {
            -tour    : Object
            -form    : Object
            -loading : boolean
            -error   : String
            +handleSubmit() : void
            +render() : JSX
        }
    }

    package "components/itinerary" {
        class ItineraryList {
            -tourId      : Long
            -durationDays: Integer
            -tourStatus  : String
            -itineraries : TourItineraryDTO[]
            -showForm    : boolean
            -editingItem : Object
            +fetchItineraries(): void
            +handleDelete(item): void
            +render() : JSX
        }
        class ItineraryForm {
            -tourId      : Long
            -durationDays: Integer
            -itinerary   : Object
            -form        : Object
            -loading     : boolean
            -error       : String
            +handleSubmit() : void
            +render() : JSX
        }
    }

    package "components/guide" {
        class GuideCard {
            -guide     : TourGuideDTO
            -selectable: boolean
            -selected  : boolean
            -warning   : String
            +render() : JSX
        }
        class GuideFilter {
            -filters    : Object
            -hideStatus : boolean
            +onChange() : void
            +render() : JSX
        }
    }

    package "components/assignment" {
        class AssignmentForm {
            -tour              : TourDetailDTO
            -existingAssignments : AssignmentDTO[]
            -selectedGuides    : Object[]
            -filters           : Object
            -saving            : boolean
            -eligibleGuides    : TourGuideDTO[]
            -ineligibleGuides  : TourGuideDTO[]
            +handleSelectGuide(guide) : void
            +handleSubmit()    : void
            +render() : JSX
        }
        class AssignmentList {
            -assignments : AssignmentDTO[]
            +handleCancel(id) : void
            +render() : JSX
        }
    }

    package "api (axios)" {
        class tourApi {
            +getAll(activeOnly) : Promise
            +getById(id) : Promise
            +create(data) : Promise
            +update(id, data) : Promise
            +cancel(id) : Promise
        }
        class itineraryApi {
            +getByTour(tourId) : Promise
            +create(tourId, data) : Promise
            +update(tourId, itemId, data) : Promise
            +delete(tourId, itemId) : Promise
        }
        class guideApi {
            +getAll(filters) : Promise
            +getById(id) : Promise
            +getForTour(tourId, filters) : Promise
        }
        class assignmentApi {
            +getByTour(tourId) : Promise
            +save(request) : Promise
            +cancel(assignmentId) : Promise
        }
    }
}

' ============================
' SERVER – Spring Boot
' ============================
package "Server – Spring Boot" #E8F5E9 {

    ' ----- Controller Layer -----
    package "Controller Layer" {
        class TourController {
            -tourService : TourService
            +getAllTours(activeOnly, keyword, status) : ResponseEntity
            +getTourById(id : Long) : ResponseEntity
            +createTour(request : TourRequestDTO) : ResponseEntity
            +updateTour(id : Long, request : TourRequestDTO) : ResponseEntity
            +cancelTour(id : Long) : ResponseEntity
        }
        class TourItineraryController {
            -itineraryService : TourItineraryService
            +getItineraries(tourId : Long) : ResponseEntity
            +createItinerary(tourId : Long, request : TourItineraryRequestDTO) : ResponseEntity
            +updateItinerary(tourId : Long, itemId : Long, request : TourItineraryRequestDTO) : ResponseEntity
            +deleteItinerary(tourId : Long, itemId : Long) : ResponseEntity
        }
        class TourGuideController {
            -guideService : TourGuideService
            +getGuides(status, specialization, language, region) : ResponseEntity
            +getGuideById(id : Long) : ResponseEntity
            +getGuidesForTour(tourId, specialization, language, region) : ResponseEntity
        }
        class TourAssignmentController {
            -assignmentService : TourAssignmentService
            +getAssignmentsByTour(tourId : Long) : ResponseEntity
            +saveAssignments(request : AssignmentRequestDTO) : ResponseEntity
            +cancelAssignment(id : Long) : ResponseEntity
        }
    }

    ' ----- Service Layer (Interfaces) -----
    package "Service Layer (Interface)" {
        interface TourService <<interface>> {
            +getAllTours() : List<TourSummaryDTO>
            +getActiveTours() : List<TourSummaryDTO>
            +searchTours(keyword, status) : List<TourSummaryDTO>
            +getTourById(id : Long) : TourDetailDTO
            +createTour(request : TourRequestDTO) : TourSummaryDTO
            +updateTour(id : Long, request : TourRequestDTO) : TourSummaryDTO
            +cancelTour(id : Long) : void
        }
        interface TourItineraryService <<interface>> {
            +getByTourId(tourId : Long) : List<TourItineraryDTO>
            +create(tourId : Long, request : TourItineraryRequestDTO) : TourItineraryDTO
            +update(tourId, itemId, request) : TourItineraryDTO
            +delete(tourId : Long, itemId : Long) : void
        }
        interface TourGuideService <<interface>> {
            +getAllGuides() : List<TourGuideDTO>
            +getGuideById(id : Long) : TourGuideDTO
            +filterGuides(status, spec, lang, region) : List<TourGuideDTO>
            +getGuidesForTour(tourId, spec, lang, region) : List<TourGuideDTO>
        }
        interface TourAssignmentService <<interface>> {
            +getAssignmentsByTourId(tourId : Long) : List<AssignmentDTO>
            +saveAssignments(request : AssignmentRequestDTO) : List<AssignmentDTO>
            +cancelAssignment(assignmentId : Long) : void
        }
    }

    ' ----- Service Layer (Implementations) -----
    package "Service Layer (Impl)" {
        class TourServiceImpl {
            -tourRepository : TourRepository
            -assignmentRepository : TourAssignmentRepository
            -itineraryRepository : TourItineraryRepository
            +getAllTours() : List<TourSummaryDTO>
            +getActiveTours() : List<TourSummaryDTO>
            +searchTours(keyword, status) : List<TourSummaryDTO>
            +getTourById(id : Long) : TourDetailDTO
            +createTour(request : TourRequestDTO) : TourSummaryDTO
            +updateTour(id : Long, request : TourRequestDTO) : TourSummaryDTO
            +cancelTour(id : Long) : void
            -toSummaryDTO(tour : Tour) : TourSummaryDTO
            -toDetailDTO(tour, itineraries) : TourDetailDTO
            -toItineraryDTO(it : TourItinerary) : TourItineraryDTO
            -toAssignmentDTO(a : TourAssignment) : AssignmentDTO
        }
        class TourItineraryServiceImpl {
            -itineraryRepository : TourItineraryRepository
            -tourRepository : TourRepository
            +getByTourId(tourId : Long) : List<TourItineraryDTO>
            +create(tourId, request) : TourItineraryDTO
            +update(tourId, itemId, request) : TourItineraryDTO
            +delete(tourId : Long, itemId : Long) : void
            -validateTourEditable(tour : Tour) : void
            -validateDayNumber(dayNumber, durationDays) : void
            -validateTime(request) : void
            -toDTO(it : TourItinerary) : TourItineraryDTO
        }
        class TourGuideServiceImpl {
            -guideRepository : TourGuideRepository
            -tourRepository  : TourRepository
            +getAllGuides() : List<TourGuideDTO>
            +getGuideById(id : Long) : TourGuideDTO
            +filterGuides(status, spec, lang, region) : List<TourGuideDTO>
            +getGuidesForTour(tourId, spec, lang, region) : List<TourGuideDTO>
            -toDTO(guide : TourGuide) : TourGuideDTO
        }
        class TourAssignmentServiceImpl {
            -assignmentRepository : TourAssignmentRepository
            -tourRepository : TourRepository
            -guideRepository : TourGuideRepository
            +getAssignmentsByTourId(tourId : Long) : List<AssignmentDTO>
            +saveAssignments(request : AssignmentRequestDTO) : List<AssignmentDTO>
            +cancelAssignment(assignmentId : Long) : void
            -updateTourStatusIfNeeded(tour : Tour) : void
            -toDTO(a : TourAssignment) : AssignmentDTO
        }
    }

    ' ----- Repository (DAO) Layer -----
    package "Repository (DAO) Layer" {
        interface TourRepository <<interface>> {
            +findByCode(code : String) : Optional<Tour>
            +existsByCode(code : String) : boolean
            +existsByCodeAndIdNot(code, id) : boolean
            +findByStatus(status : TourStatus) : List<Tour>
            +findByIdWithAssignments(id : Long) : Optional<Tour>
            +findActiveTours() : List<Tour>
            +searchTours(keyword, status) : List<Tour>
        }
        interface TourItineraryRepository <<interface>> {
            +findByTourIdOrderByDayNumberAscSequenceOrderAsc(tourId) : List<TourItinerary>
            +existsByTourId(tourId : Long) : boolean
        }
        interface TourGuideRepository <<interface>> {
            +findByCode(code : String) : Optional<TourGuide>
            +findByStatus(status : GuideStatus) : List<TourGuide>
            +findByFilters(status, spec, lang, region) : List<TourGuide>
            +countScheduleOverlaps(guideId, startDate, endDate, excludeTourId) : long
            +findGuideIdsWithScheduleOverlap(startDate, endDate, excludeTourId) : List<Long>
        }
        interface TourAssignmentRepository <<interface>> {
            +findByTourId(tourId : Long) : List<TourAssignment>
            +findByTourIdWithDetails(tourId : Long) : List<TourAssignment>
            +existsByTourIdAndGuideIdAndStatusNot(tourId, guideId, status) : boolean
            +countActiveAssignmentsByTourId(tourId : Long) : long
        }

        class JpaRepository <<interface>> {
        }
    }

    ' ----- Model (Entity) Layer -----
    package "Model (Entity) Layer" {
        class Tour {
            -id : Long
            -code : String
            -name : String
            -description : String
            -destination : String
            -startDate : LocalDate
            -endDate : LocalDate
            -durationDays : Integer
            -maxGuests : Integer
            -currentGuests : Integer
            -price : BigDecimal
            -status : TourStatus
            -requiredLanguages : String
            -requiredSpecialization : String
            -minGuides : Integer
            -departureRegion : String
            -assignments : List<TourAssignment>
            -bookings : List<Booking>
            -itineraries : List<TourItinerary>
        }
        class TourItinerary {
            -id : Long
            -tour : Tour
            -dayNumber : Integer
            -sequenceOrder : Integer
            -title : String
            -description : String
            -location : String
            -startTime : LocalTime
            -endTime : LocalTime
            -activityType : String
            -note : String
            -isOptional : Boolean
        }
        class TourGuide {
            -id : Long
            -code : String
            -fullName : String
            -email : String
            -phone : String
            -dateOfBirth : LocalDate
            -specialization : String
            -languages : String
            -region : String
            -experienceYears : Integer
            -status : GuideStatus
            -avatarUrl : String
            -bio : String
            -assignments : List<TourAssignment>
        }
        class TourAssignment {
            -id : Long
            -tour : Tour
            -guide : TourGuide
            -role : String
            -note : String
            -status : AssignmentStatus
            -assignedAt : LocalDateTime
            -assignedBy : String
        }
    }

    ' ----- Enums -----
    package "Enums" {
        enum TourStatus {
            PLANNING
            OPEN
            FULL
            ONGOING
            COMPLETED
            CANCELLED
        }
        enum GuideStatus {
            AVAILABLE
            ON_TOUR
            ON_LEAVE
            INACTIVE
        }
        enum AssignmentStatus {
            ASSIGNED
            CONFIRMED
            CANCELLED
        }
        enum BookingStatus {
            PENDING
            CONFIRMED
            CANCELLED
            COMPLETED
        }
    }

    ' ----- DTO Layer -----
    package "DTO Layer" {
        package "Request" {
            class TourRequestDTO {
                -code : String
                -name : String
                -description : String
                -destination : String
                -startDate : LocalDate
                -endDate : LocalDate
                -maxGuests : Integer
                -price : BigDecimal
                -status : TourStatus
                -minGuides : Integer
                -requiredLanguages : String
                -requiredSpecialization : String
                -departureRegion : String
            }
            class TourItineraryRequestDTO {
                -dayNumber : Integer
                -sequenceOrder : Integer
                -title : String
                -description : String
                -location : String
                -startTime : LocalTime
                -endTime : LocalTime
                -activityType : String
                -note : String
                -isOptional : Boolean
            }
            class AssignmentRequestDTO {
                -tourId : Long
                -guides : List<GuideAssignmentItem>
            }
            class GuideAssignmentItem {
                -guideId : Long
                -role : String
                -note : String
            }
        }
        package "Response" {
            class TourSummaryDTO {
                -id : Long
                -code : String
                -name : String
                -destination : String
                -startDate : LocalDate
                -endDate : LocalDate
                -durationDays : Integer
                -maxGuests : Integer
                -currentGuests : Integer
                -price : BigDecimal
                -status : TourStatus
                -minGuides : Integer
                -assignedGuideCount : long
            }
            class TourDetailDTO {
                -id : Long
                -code : String
                -name : String
                -description : String
                -destination : String
                -startDate : LocalDate
                -endDate : LocalDate
                -durationDays : Integer
                -maxGuests : Integer
                -currentGuests : Integer
                -price : BigDecimal
                -status : TourStatus
                -requiredLanguages : String
                -requiredSpecialization : String
                -minGuides : Integer
                -departureRegion : String
                -assignments : List<AssignmentDTO>
                -itineraries : List<TourItineraryDTO>
            }
            class TourItineraryDTO {
                -id : Long
                -tourId : Long
                -dayNumber : Integer
                -sequenceOrder : Integer
                -title : String
                -description : String
                -location : String
                -startTime : LocalTime
                -endTime : LocalTime
                -activityType : String
                -note : String
                -isOptional : Boolean
            }
            class TourGuideDTO {
                -id : Long
                -code : String
                -fullName : String
                -email : String
                -phone : String
                -specialization : String
                -languages : String
                -region : String
                -experienceYears : Integer
                -status : GuideStatus
                -avatarUrl : String
                -bio : String
                -availabilityWarning : String
                -eligible : boolean
            }
            class AssignmentDTO {
                -id : Long
                -tourId : Long
                -tourCode : String
                -tourName : String
                -guideId : Long
                -guideCode : String
                -guideName : String
                -guidePhone : String
                -guideLanguages : String
                -role : String
                -note : String
                -status : AssignmentStatus
                -assignedAt : LocalDateTime
                -assignedBy : String
            }
            class "ApiResponse<T>" as ApiResponse {
                -success : boolean
                -message : String
                -data : T
                -timestamp : LocalDateTime
                +{static} ok(message, data) : ApiResponse<T>
                +{static} error(message) : ApiResponse<T>
            }
        }
    }

    ' ----- Customer & Booking Entities -----
    package "Booking Domain" {
        class Customer {
            -id : Long
            -code : String
            -fullName : String
            -phone : String
            -email : String
            -createdAt : LocalDateTime
        }
        class Booking {
            -id : Long
            -bookingCode : String
            -tour : Tour
            -customer : Customer
            -bookingDate : LocalDate
            -numberOfGuests : Integer
            -unitPrice : BigDecimal
            -discountAmount : BigDecimal
            -totalAmount : BigDecimal
            -status : BookingStatus
            -createdAt : LocalDateTime
        }
    }

    ' ----- Report Layer -----
    package "Report Layer" {
        interface ReportService <<interface>> {
            +getTourRevenueReport(fromDate, toDate, status, destination, sortBy) : RevenueReportDTO
        }
        class ReportServiceImpl {
            -tourRepository : TourRepository
            -bookingRepository : BookingRepository
            +getTourRevenueReport(...) : RevenueReportDTO
            -sortTourRevenues(list, sortBy) : void
        }
        class ReportController {
            -reportService : ReportService
            +getTourRevenue(fromDate, toDate, status, destination, sortBy) : ResponseEntity
        }
        interface BookingRepository <<interface>> {
            +aggregateRevenueByTour(statuses) : List<TourRevenueProjection>
        }
        interface CustomerRepository <<interface>> {
            +findByCode(code) : Optional<Customer>
        }
        interface TourRevenueProjection <<interface>> {
            +getTourId() : Long
            +getTotalGuests() : Long
            +getTotalRevenue() : BigDecimal
        }
    }

    ' ----- Report DTOs -----
    package "Report DTO" {
        class TourRevenueDTO {
            -tourId : Long
            -tourCode : String
            -tourName : String
            -destination : String
            -startDate : LocalDate
            -totalGuests : Long
            -totalRevenue : BigDecimal
        }
        class RevenueSummaryDTO {
            -totalTours : int
            -totalGuests : Long
            -totalRevenue : BigDecimal
        }
        class RevenueReportDTO {
            -summary : RevenueSummaryDTO
            -tours : List<TourRevenueDTO>
        }
    }

    ' ----- Exception Layer -----
    package "Exception Layer" {
        class BusinessException {
            -status : HttpStatus
            +getStatus() : HttpStatus
        }
        class ResourceNotFoundException {
            +ResourceNotFoundException(resourceName, id)
        }
        class GlobalExceptionHandler {
            +handleBusinessException(ex) : ResponseEntity
            +handleNotFound(ex) : ResponseEntity
            +handleValidation(ex) : ResponseEntity
            +handleGeneral(ex) : ResponseEntity
        }
    }

    ' ----- Config -----
    package "Config" {
        class CorsConfig {
            +addCorsMappings(registry) : void
        }
    }
}

